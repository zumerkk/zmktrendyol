# ─── Database ─────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/zmktrendyol"
DIRECT_URL="postgresql://user:password@host:5432/zmktrendyol"
REDIS_URL="redis://localhost:6379"

# ─── Auth ─────────────────────────────────────
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-32"
JWT_EXPIRATION="1d"
JWT_REFRESH_EXPIRATION="7d"
ENCRYPTION_KEY="32-byte-hex-key-for-aes-256-gcm"

# ─── Trendyol API ─────────────────────────────
TRENDYOL_API_BASE_URL="https://api.trendyol.com/sapigw"
TRENDYOL_SELLER_ID=""
TRENDYOL_API_KEY=""
TRENDYOL_API_SECRET=""
TRENDYOL_API_TOKEN=""

# ─── AI Providers ─────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
GROQ_API_KEY=""
ELEVENLABS_API_KEY=""

# ─── Scraper & Anti-Detect ────────────────────
PROXY_POOL_URL=""
PROXY_POOL_API_KEY=""
SCRAPER_CONCURRENCY=3
SCRAPER_DELAY_MS=5000

# ─── Buybox & Dynamic Pricing ────────────────
BUYBOX_CHECK_INTERVAL_MIN=30
STOCK_PROBE_INTERVAL_MIN=60
AUTO_PRICING_ENABLED=false

# ─── Telegram Bot ─────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ─── Trello ──────────────────────────────────
TRELLO_API_KEY=""
TRELLO_TOKEN=""

# ─── App ─────────────────────────────────────
NODE_ENV="production"
API_PORT=4000
DASHBOARD_URL="https://your-dashboard.onrender.com"
API_URL="https://your-api.onrender.com"
API_BASE="https://your-api.onrender.com/api"
